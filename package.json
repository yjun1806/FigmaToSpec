{
  "name": "figma-to-spec",
  "private": true,
  "packageManager": "pnpm@9.14.4",
  "scripts": {
    "build": "turbo run build",
    "build:watch": "turbo run build:watch",
    "dev": "turbo run dev --concurrency 20",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\""
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "eslint-config-custom": "workspace:*",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  }
}
